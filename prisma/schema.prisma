// Prisma Schema - Drum School Management
// Database: SQLite (local development)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// ENUMS (SQLite no soporta enums nativos, usamos strings)
// ============================================

// Role: "TEACHER" | "STUDENT"
// ClassStatus: "SCHEDULED" | "CONFIRMED" | "COMPLETED" | "CANCELLED" | "NO_SHOW" | "RESCHEDULED"
// PaymentStatus: "PENDING" | "PAID" | "OVERDUE" | "CANCELLED"
// StudentStatus: "PROSPECT" | "TRIAL" | "ACTIVE" | "INACTIVE" | "PAUSED"
// LeadSource: "INSTAGRAM" | "FACEBOOK" | "GOOGLE" | "REFERRAL" | "WEBSITE" | "OTHER"

// ============================================
// USUARIOS Y AUTENTICACIÓN
// ============================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  password      String    // Hasheado con bcrypt
  role          String    @default("STUDENT") // "TEACHER" | "STUDENT"
  image         String?
  phone         String?
  
  // Relaciones
  teacherProfile TeacherProfile?
  studentProfile StudentProfile?
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model TeacherProfile {
  id            String    @id @default(cuid())
  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Configuración
  timezone      String    @default("America/Santiago")
  currency      String    @default("CLP")
  
  // Metas y KPIs
  monthlyStudentGoal    Int?
  breakEvenPoint        Float?
  targetMonthlyRevenue  Float?
  
  // Relaciones
  students      StudentProfile[]
  availability  Availability[]
  availabilityExceptions AvailabilityException[]
  pricingPlans  PricingPlan[]
  classTypes    ClassType[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model StudentProfile {
  id            String        @id @default(cuid())
  userId        String        @unique
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  teacherId     String
  teacher       TeacherProfile @relation(fields: [teacherId], references: [id])
  
  // Estado del alumno
  status        String    @default("PROSPECT") // PROSPECT | TRIAL | ACTIVE | INACTIVE | PAUSED
  leadSource    String?   // INSTAGRAM | FACEBOOK | GOOGLE | REFERRAL | WEBSITE | OTHER
  
  // Información de contacto adicional
  emergencyContact  String?
  emergencyPhone    String?
  
  // Preferencias
  preferredDay      String?   // "Monday", "Wednesday", etc.
  preferredTime     String?   // "09:00", "14:00"
  modalidad         String?   // "online" o "presencial"
  
  // Métricas
  totalClassesTaken     Int      @default(0)
  totalMonthsActive     Int      @default(0)
  lifetimeValue         Float    @default(0)
  lastClassDate         DateTime?
  acquisitionCost       Float?
  
  // Control de reagendamientos
  reschedulesThisMonth  Int      @default(0)
  lastRescheduleReset   DateTime @default(now())
  
  // Relaciones
  classes       Class[]
  payments      Payment[]
  tasks         Task[]
  notes         ClassNote[]
  subscriptions Subscription[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ============================================
// CLASES Y CALENDARIO
// ============================================

model Class {
  id            String      @id @default(cuid())
  
  studentId     String?     // Opcional para bookings públicos
  student       StudentProfile? @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  // Detalles de la clase
  scheduledDate DateTime?   // Fecha original (opcional por compatibilidad)
  date          DateTime?   // Nueva fecha (para compatibilidad con nuevo sistema)
  startTime     String?     // "14:00" - para nuevo sistema
  endTime       String?     // "15:00" - para nuevo sistema
  duration      Int         @default(60) // minutos
  status        String      @default("SCHEDULED") // SCHEDULED | CONFIRMED | COMPLETED | CANCELLED | NO_SHOW | RESCHEDULED | DELETED
  modalidad     String?     // "online" o "presencial"
  
  // Tracking
  isTrialClass  Boolean     @default(false)
  classNumber   Int?        // 1 de 4, 2 de 4, etc.
  totalInPlan   Int?        // total de clases del plan (4, 8, etc.)
  
  // Confirmación
  confirmedAt   DateTime?
  confirmedBy   String?     // "student" o "teacher"
  
  // Cancelación/Reagendamiento
  cancelledAt   DateTime?
  cancelReason  String?
  rescheduledFrom String?   // ID de la clase original
  
  // Eliminación (soft delete)
  deletedAt     DateTime?
  
  // Realización
  completedAt   DateTime?
  attendanceMarked Boolean   @default(false)
  
  // NUEVO: Tipo de clase
  classTypeId   String?
  classType     ClassType? @relation(fields: [classTypeId], references: [id])
  
  // NUEVO: Relación con booking público
  bookingId     String?
  singleBooking Booking?   @relation("SingleClass")
  multiBooking  Booking?   @relation("MultipleClasses", fields: [bookingId], references: [id])
  
  // NUEVO: Recuperación y reagendamiento
  isRecovery    Boolean     @default(false) // si es clase de recuperación
  recoveryExpiresAt DateTime? // expira en 20 días
  originalScheduledDate DateTime? // fecha original si es recuperación/reagendamiento
  
  // NUEVO: Tracking detallado de asistencia
  attendanceStatus String?   // ATTENDED | NO_SHOW | CANCELLED_BY_TEACHER | CANCELLED_BY_STUDENT
  cancelledWithin48h Boolean @default(false) // si se canceló con menos de 48hrs
  
  // NUEVO: Plan Mensual Dinámico
  needsRenewalReminder Boolean   @default(false) // Marcar penúltima clase
  expiresAt            DateTime? // Fecha de expiración
  
  // Relaciones
  notes         ClassNote[]
  tasks         Task[]
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model ClassNote {
  id            String    @id @default(cuid())
  
  classId       String
  class         Class     @relation(fields: [classId], references: [id], onDelete: Cascade)
  
  studentId     String
  student       StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  // Contenido
  content       String    // Texto libre de la clase
  topics        String    // JSON array: ["ritmo básico", "coordinación"]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Task {
  id            String    @id @default(cuid())
  
  classId       String?
  class         Class?    @relation(fields: [classId], references: [id], onDelete: SetNull)
  
  studentId     String
  student       StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  // Tarea
  title         String
  description   String
  dueDate       DateTime?
  completed     Boolean   @default(false)
  completedAt   DateTime?
  
  // Comentarios del profesor
  feedback      String?
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Availability {
  id            String    @id @default(cuid())
  
  teacherId     String
  teacher       TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  
  // Configuración de disponibilidad
  dayOfWeek     Int       // 0 = Domingo, 1 = Lunes, ..., 6 = Sábado
  startTime     String    // "09:00"
  endTime       String    // "18:00"
  slotDuration  Int       @default(60) // minutos por slot
  
  isActive      Boolean   @default(true)
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  @@unique([teacherId, dayOfWeek, startTime])
}

// ============================================
// PAGOS Y FACTURACIÓN
// ============================================

model PricingPlan {
  id            String    @id @default(cuid())
  
  teacherId     String
  teacher       TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  
  // Detalles del plan
  name          String    // "Mensualidad", "Clase de Prueba"
  description   String?
  price         Float
  currency      String    @default("CLP")
  
  classesIncluded Int     // 1, 4, 8, etc.
  validityDays    Int     // 30, 60, 90 días
  
  isTrialPlan   Boolean   @default(false)
  isActive      Boolean   @default(true)
  
  // Relaciones
  subscriptions Subscription[]
  payments      Payment[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Subscription {
  id            String    @id @default(cuid())
  
  studentId     String
  student       StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  planId        String
  plan          PricingPlan @relation(fields: [planId], references: [id])
  
  // Vigencia
  startDate     DateTime
  endDate       DateTime
  
  // Uso
  classesUsed   Int       @default(0)
  classesTotal  Int
  
  isActive      Boolean   @default(true)
  autoRenew     Boolean   @default(false)
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Payment {
  id            String        @id @default(cuid())
  
  studentId     String
  student       StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  planId        String?
  plan          PricingPlan?  @relation(fields: [planId], references: [id])
  
  // Detalles del pago
  amount        Float
  currency      String        @default("CLP")
  status        String        @default("PENDING") // PENDING | PAID | OVERDUE | CANCELLED
  method        String        @default("TRANSFER") // TRANSFER | CASH | MERCADOPAGO | OTHER
  
  // Mercado Pago
  mercadoPagoId String?       @unique
  paymentLink   String?
  isAutomatic   Boolean       @default(false)
  
  // Metadata
  description   String?
  dueDate       DateTime?
  paidAt        DateTime?
  referenceNumber String?     // Número de comprobante
  notes         String?       // Notas adicionales
  receiptUrl    String?       // URL del comprobante
  
  // Relación con plan/clase (legacy - mantenido por compatibilidad)
  forPlan       String?       // ID del plan
  forMonth      String?       // "2026-01" para mensualidades
  
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

// ============================================
// CRM & PROSPECCIÓN
// ============================================

model Lead {
  id            String      @id @default(cuid())
  
  // Información de contacto
  name          String
  email         String?
  phone         String?
  
  // Origen
  source        String      // INSTAGRAM | FACEBOOK | GOOGLE | REFERRAL | WEBSITE | OTHER
  sourceDetail  String?     // Ej: "Post de Instagram del 15 de enero"
  
  // Estado del lead
  status        String      @default("new") // new | contacted | scheduled | converted | lost
  
  // Interacción
  notes         String?
  lastContactDate DateTime?
  
  // Conversión
  convertedToStudentId String? @unique
  convertedAt          DateTime?
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

// ============================================
// AUTOMATIZACIONES & IA
// ============================================

model AutomationLog {
  id            String    @id @default(cuid())
  
  // Tipo de automatización
  type          String    // "email", "whatsapp", "payment_reminder", etc.
  
  // Destinatario
  recipientId   String
  recipientType String    // "student", "teacher"
  
  // Contenido
  subject       String?
  body          String?
  
  // Estado
  status        String    // "sent", "failed", "pending"
  sentAt        DateTime?
  
  // Error handling
  errorMessage  String?
  retryCount    Int       @default(0)
  
  createdAt     DateTime  @default(now())
}

// ============================================
// AGENDAMIENTO PÚBLICO
// ============================================

// Bloqueos de disponibilidad (vacaciones, feriados)
model AvailabilityException {
  id            String    @id @default(cuid())
  
  teacherId     String
  teacher       TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  
  date          DateTime  // Fecha bloqueada (solo día, sin hora)
  reason        String?   // "Vacaciones", "Feriado", etc.
  
  createdAt     DateTime  @default(now())
  
  @@unique([teacherId, date])
}

// Tipos de clase públicos (simplificado vs PricingPlan)
model ClassType {
  id            String    @id @default(cuid())
  
  teacherId     String
  teacher       TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  
  // Info básica
  name          String    // "Clase de Prueba"
  description   String?   // "Primera clase sin compromiso"
  icon          String?   // "🎵"
  
  // Precio y duración
  price         Float     // 25000
  currency      String    @default("CLP")
  duration      Int       @default(60) // minutos
  
  // Control
  isActive      Boolean   @default(true)
  sortOrder     Int       @default(0) // Para ordenar en formulario público
  
  // Relaciones
  bookings      Booking[]
  classes       Class[]
  restriction   ClassTypeRestriction?
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// Reservas públicas (antes de crear cuenta de alumno)
model Booking {
  id            String    @id @default(cuid())
  
  // Datos del solicitante
  name          String
  email         String
  phone         String
  message       String?
  
  // Detalles de la clase
  classTypeId   String
  classType     ClassType @relation(fields: [classTypeId], references: [id])
  
  date          DateTime  // Fecha completa con hora
  startTime     String    // "14:00"
  endTime       String    // "15:00"
  
  // Estado
  status        String    @default("PENDING") // PENDING | CONFIRMED | CONVERTED | CANCELLED
  
  // Conversión a clase
  classId       String?   @unique
  class         Class?    @relation("SingleClass", fields: [classId], references: [id])
  classes       Class[]   @relation("MultipleClasses") // Para plan mensual
  
  // NUEVO: Plan Mensual
  isParent      Boolean   @default(false) // true si es booking padre de plan mensual
  parentBookingId String? // referencia al booking padre si es hijo
  parentBooking Booking?  @relation("BookingHierarchy", fields: [parentBookingId], references: [id], onDelete: Cascade)
  childBookings Booking[] @relation("BookingHierarchy")
  
  // NUEVO: Recuperación
  isRecovery    Boolean   @default(false) // si es clase de recuperación
  recoveryExpiresAt DateTime? // expira en 20 días si es recuperación
  originalClassDate DateTime? // fecha original si es recuperación
  
  // NUEVO: Reagendamiento
  rescheduledCount Int     @default(0) // cuántas veces se reagendó
  rescheduledFromDate DateTime? // fecha original antes de reagendar
  
  // NUEVO: Plan Mensual Dinámico
  totalPrice    Int?      // Precio calculado dinámicamente
  isMonthlyPlan Boolean   @default(false) // Indicador de Plan Mensual
  
  // Tracking
  confirmedAt   DateTime?
  cancelledAt   DateTime?
  cancelReason  String?
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// Restricciones configurables por tipo de clase
model ClassTypeRestriction {
  id            String    @id @default(cuid())
  
  classTypeId   String    @unique
  classType     ClassType @relation(fields: [classTypeId], references: [id], onDelete: Cascade)
  
  // Días permitidos (JSON array)
  allowedDays   String?   // ["Monday", "Wednesday", "Saturday"]
  
  // Rangos horarios permitidos (JSON array de arrays)
  allowedTimeRanges String? // [["09:00", "13:00"], ["14:00", "18:00"]]
  
  // Límites
  maxPerWeek    Int?      // Máximo de clases de este tipo por semana
  maxPerDay     Int?      // Máximo de clases de este tipo por día
  
  // Control
  requiresApproval Boolean @default(false) // Si requiere aprobación manual
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// Tracking de límites mensuales por usuario
model MonthlyLimits {
  id            String    @id @default(cuid())
  
  email         String
  phone         String
  month         String    // "2026-01" formato YYYY-MM
  
  // Límites de clase de prueba
  trialClassesTaken Int   @default(0) // Máximo 1
  
  // Límites de reagendamiento (máximo 2 al mes)
  reschedulesUsed Int     @default(0)
  
  // Límites de recuperación (máximo 2 al mes)
  recoveriesUsed Int      @default(0)
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  @@unique([email, phone, month])
}
